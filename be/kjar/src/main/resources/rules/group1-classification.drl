                                         state != PumpState.IDLE,
                                         timestamp < $reading.timestamp)
    then
        modify($existing) {
            setState(PumpState.IDLE),
            setTimestamp($reading.getTimestamp())
        };
end

rule "Azuriranje statusa pumpe - FAULTY"
    salience 100
    when
        $reading: SensorReading(sensorType == SensorType.PUMP_STATUS,
                                $loc: location, $pumpId: sensorName, value == -1.0)
        $existing: PumpOperationalStatus(location == $loc, pumpId == $pumpId,
                                         state != PumpState.FAULTY,
                                         timestamp < $reading.timestamp)
    then
        modify($existing) {
